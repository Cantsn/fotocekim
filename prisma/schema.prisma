generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String   @default("")
  /// JSON string array of Permission keys. Owner ignores this (full access).
  permissions  String   @default("[]")
  isOwner      Boolean  @default(false)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SiteSettings {
  id             String  @id @default("default")
  siteName       String
  tagline        String  @default("")
  phone          String  @default("")
  whatsapp       String  @default("")
  email          String  @default("")
  address        String  @default("")
  city           String  @default("")
  instagram      String  @default("")
  youtube        String  @default("")
  tiktok         String  @default("")
  /// Instagram Graph API (Business/Creator) — portföy içe aktarma
  instagramUserId       String @default("")
  instagramAccessToken  String @default("")
  showPrices     Boolean @default(true)
  seoTitle       String  @default("")
  seoDescription String  @default("")
  /// Ana sayfa hero: NONE | IMAGE | VIDEO
  heroMediaType  String  @default("NONE")
  heroMediaUrl   String  @default("")
  /// Video için poster / kapak görseli (opsiyonel)
  heroPosterUrl  String  @default("")
  /// SMTP
  smtpEnabled    Boolean @default(false)
  smtpHost       String  @default("")
  smtpPort       Int     @default(587)
  smtpUser       String  @default("")
  smtpPassword   String  @default("")
  smtpFrom       String  @default("")
  smtpSecure     Boolean @default(true)
  /// Randevu müsaitlik
  workStartHour      Int    @default(9)
  workEndHour        Int    @default(18)
  slotMinutes        Int    @default(60)
  /// JSON: 0=Pazar ... 6=Cumartesi — varsayılan Pzt–Cmt
  workDays           String @default("[1,2,3,4,5,6]")
  bookingHorizonDays Int    @default(90)
  /// Google Calendar OAuth
  googleCalEnabled      Boolean @default(false)
  googleCalId           String  @default("primary")
  googleCalRefreshToken String  @default("")
  googleCalAccessToken  String  @default("")
  googleCalTokenExpiry  DateTime?
  googleCalEmail        String  @default("")
}

/// Ana sayfa duyuru / kampanya bandı
model Announcement {
  id          String    @id @default(cuid())
  title       String
  message     String    @default("")
  linkUrl     String    @default("")
  linkLabel   String    @default("")
  /// accent | dark | soft
  style       String    @default("accent")
  active      Boolean   @default(false)
  /// Opsiyonel yayın aralığı (YYYY-MM-DD)
  startsAt    String?
  endsAt      String?
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Service {
  id        String         @id @default(cuid())
  slug      String         @unique
  title     String
  shortDesc String         @default("")
  content   String         @default("")
  /// Liste kartı + detay hero
  coverUrl  String?
  order     Int            @default(0)
  published Boolean        @default(true)
  images    ServiceImage[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model ServiceImage {
  id        String   @id @default(cuid())
  serviceId String
  url       String
  alt       String   @default("")
  order     Int      @default(0)
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Package {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String   @default("")
  priceFrom   Int?
  currency    String   @default("TRY")
  /// NONE | PERCENT | AMOUNT
  discountType  String  @default("NONE")
  /// PERCENT: 1-100, AMOUNT: TL tutarı
  discountValue Int?
  /// JSON array string
  features    String   @default("[]")
  highlight   Boolean  @default(false)
  order       Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Project {
  id              String    @id @default(cuid())
  slug            String    @unique
  title           String
  clientFirstName String?
  clientLastName  String?
  /// Eski alan / görünen tam isim yedek
  clientName      String?
  location        String?
  /// Plato / set / stüdyo bilgisi
  plato           String?
  date            DateTime?
  category        String    @default("dugun")
  description     String    @default("")
  coverUrl        String?
  published       Boolean   @default(true)
  featured        Boolean   @default(false)
  order           Int       @default(0)
  images          ProjectImage[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model ProjectImage {
  id        String   @id @default(cuid())
  projectId String
  url       String
  alt       String   @default("")
  order     Int      @default(0)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  role      String?
  content   String
  rating    Int      @default(5)
  published Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model Faq {
  id        String  @id @default(cuid())
  question  String
  answer    String
  order     Int     @default(0)
  published Boolean @default(true)
}

model Inquiry {
  id        String   @id @default(cuid())
  name      String
  phone     String
  email     String?
  type      String   @default("OTHER")
  /// YYYY-MM-DD
  eventDate String?
  /// HH:mm başlangıç saati (slot)
  eventTime String?
  location  String?
  message   String
  budget    String?
  /// NEW | READ | QUOTED | CONFIRMED | CANCELLED
  status    String   @default("NEW")
  source    String?
  /// Google Calendar event id (OAuth sync)
  googleEventId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Admin’in manuel kapattığı gün/saatler (tatil, özel çekim vb.)
model BlockedSlot {
  id        String   @id @default(cuid())
  /// YYYY-MM-DD
  date      String
  /// null = tüm gün kapalı; doluysa HH:mm
  time      String?
  reason    String   @default("")
  createdAt DateTime @default(now())
}

/// Özel gün / tatil / anma günü (randevu UI + müsaitlik)
model SpecialDay {
  id           String  @id @default(cuid())
  /// YYYY-MM-DD
  date         String
  title        String
  /// HOLIDAY | SPECIAL | CLOSED
  type         String  @default("SPECIAL")
  note         String  @default("")
  /// true ise o gün randevu alınamaz
  blockBooking Boolean @default(true)
  createdAt    DateTime @default(now())
}
